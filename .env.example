# Local credentials for gemini-explicit-cache.ts
# Copy this file to .env and fill values. Do not commit .env.
# Most users should keep this file minimal and pass flags in CLI.

GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=

# Optional stable defaults (usually okay to leave commented)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_CACHE_TTL=1200s

# Optional output file pattern
# Timestamp placeholders supported in .env values:
# ${YYYYMMDD-HHMM}, ${YYYYMMDD_HHMM}, ${YYYYMMDDHHMM}, ${YYYYMMDD}, ${HHMM}
# GEMINI_CACHE_OUT=out/${YYYYMMDD-HHMM}.json

# Advanced optional conveniences (recommended to leave unset):
# GEMINI_QUERY_PROMPT=...
# GEMINI_LIST_PAGE_SIZE=20
# GEMINI_CACHE_FILES=path1.txt,path2.md,path3.png
# GEMINI_SYSTEM_FILE=path/to/system-prompt.txt
# GEMINI_SYSTEM=You are a helpful assistant.
# GEMINI_CACHE_NAME=cachedContents/...
